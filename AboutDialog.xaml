<Window x:Class="x264video4osu.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource About}"
        Width="440"
        Height="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Background="#F9FAFB"
        WindowStyle="SingleBorderWindow">

    <Window.Resources>
        <!-- 超链接样式 -->
        <Style x:Key="HyperlinkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#2563EB"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock>
                            <Hyperlink TextDecorations="None">
                                <Run Text="{TemplateBinding Content}"/>
                                <Hyperlink.Style>
                                    <Style TargetType="Hyperlink">
                                        <Setter Property="Foreground" Value="#2563EB"/>
                                        <Setter Property="TextDecorations" Value="None"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="#1D4ED8"/>
                                                <Setter Property="TextDecorations" Value="Underline"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Hyperlink.Style>
                            </Hyperlink>
                        </TextBlock>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题和版本 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="x264video4osu"
                       FontSize="26"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Foreground="#111827"
                       Margin="0,0,0,6"/>
            <TextBlock x:Name="VersionText"
                       Text="{DynamicResource VersionPlaceholder}"
                       FontSize="13"
                       HorizontalAlignment="Center"
                       Foreground="#6B7280"/>
        </StackPanel>

        <!-- 描述和链接 -->
        <StackPanel Grid.Row="1" Margin="0,0,0,24">
            <TextBlock x:Name="DescriptionText"
                       xml:space="preserve"
                       TextAlignment="Center"
                       FontSize="14"
                       Foreground="#374151"
                       LineHeight="22"
                       Margin="0,0,0,32"/>

            <!-- 链接区域 -->
            <StackPanel HorizontalAlignment="Center">
                <Button Style="{StaticResource HyperlinkButtonStyle}"
                        Content="{DynamicResource ProjectRepository}"
                        Click="Repository_Click"
                        Margin="0,0,0,12"/>

                <Button Style="{StaticResource HyperlinkButtonStyle}"
                        Content="{DynamicResource UserManual}"
                        Click="Wiki_Click"/>
            </StackPanel>
        </StackPanel>

        <!-- 关闭按钮 -->
        <Button Grid.Row="2"
                Content="{DynamicResource Close}"
                Width="100"
                Height="32"
                HorizontalAlignment="Center"
                Click="Close_Click"/>
    </Grid>
</Window>