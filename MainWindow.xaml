<Window x:Class="x264video4osu.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="x264video4osu"
        Width="500"
        Height="400"
        MinWidth="480"
        MinHeight="380"
        AllowDrop="True"
        Drop="Input_Drop">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ==================== Main Content ==================== -->
        <TabControl Grid.Row="0">
            <TabItem Header="{DynamicResource MainTab}">
                <Border Background="#F8F9FA"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="10,8">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <!-- Input File -->
                            <StackPanel Orientation="Horizontal"
                                    Margin="0,0,0,8">
                                <Label Content="{DynamicResource InputVideo}"
                                       Width="90"
                                        VerticalAlignment="Center"/>
                                <TextBox x:Name="InputPathBox"
                                         Margin="6,0"
                                         Width="0"
                                         HorizontalAlignment="Stretch"
                                         VerticalContentAlignment="Center"
                                         MinWidth="240"/>
                                <Button Content="{DynamicResource Browse}"
                                        Width="50"
                                        Margin="6,0,0,0"
                                        Padding="6,2"
                                        Click="BrowseInput_Click"/>
                            </StackPanel>

                            <!-- Output File -->
                            <StackPanel Orientation="Horizontal"
                                    Margin="0,0,0,8">
                                <Label Content="{DynamicResource OutputVideo}"
                                       Width="90"
                                        VerticalAlignment="Center"/>
                                <TextBox x:Name="OutputPathBox"
                                         Margin="6,0"
                                         Width="0"
                                         HorizontalAlignment="Stretch"
                                         VerticalContentAlignment="Center"
                                         MinWidth="240"/>
                                <Button Content="{DynamicResource Browse}"
                                        Width="50"
                                        Margin="6,0,0,0"
                                        Padding="6,2"
                                        Click="BrowseOutput_Click"/>
                            </StackPanel>

                            <!-- Separate Line -->
                            <Border Height="1"
                                    Background="#E0E0E0"
                                    Margin="0,6,0,8"/>

                            <!-- Args Settings -->
                            <StackPanel Margin="0,0,0,8">

                                <!-- Encoding Mode Selection: 2pass / CRF -->
                                <StackPanel Orientation="Horizontal"
                                        Margin="0,0,0,6">
                                    <Label Content="{DynamicResource EncodingStandard}"
                                           Width="90"
                                            VerticalAlignment="Center"/>
                                    <StackPanel Orientation="Horizontal">
                                        <RadioButton x:Name="TwoPassRadio"
                                                Content="2pass"
                                                IsChecked="True"
                                                Margin="0,0,6,0"
                                                VerticalAlignment="Center"
                                                GroupName="EncodeMode"
                                                Checked="EncodeMode_Changed"/>
                                        <RadioButton x:Name="CrfRadio"
                                                Content="CRF"
                                                Margin="0,0,6,0"
                                                VerticalAlignment="Center"
                                                GroupName="EncodeMode"
                                                Checked="EncodeMode_Changed"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Bitrate / CRF Value Box -->
                                <StackPanel Orientation="Horizontal"
                                        Margin="0,0,0,6">
                                    <Label Content=""
                                           Width="90"
                                            VerticalAlignment="Center"/>
                                    <TextBox x:Name="BitrateBox"
                                             Width="80"
                                             Text="800"
                                             VerticalContentAlignment="Center"
                                             Margin="6,0,0,0"/>
                                </StackPanel>

                                <!-- Resolution -->
                                <StackPanel Orientation="Horizontal"
                                        Margin="0,0,0,6">
                                    <Label Content="{DynamicResource Resolution}"
                                           Width="90"
                                            VerticalAlignment="Center"/>
                                    <Label Content="{DynamicResource Width}"
                                           Margin="6,0,2,0"
                                           VerticalAlignment="Center"/>
                                    <TextBox x:Name="WidthBox"
                                             Width="60"
                                             Text="0"
                                             VerticalContentAlignment="Center"
                                             Margin="0,0,8,0"/>
                                    <Label Content="{DynamicResource Height}"
                                           Margin="0,0,2,0"
                                           VerticalAlignment="Center"/>
                                    <TextBox x:Name="HeightBox"
                                             Width="60"
                                             Text="720"
                                             VerticalContentAlignment="Center"/>
                                </StackPanel>

                            </StackPanel>

                            <!-- CheckBoxes -->
                            <StackPanel Margin="0,0,0,8">
                                <CheckBox x:Name="ScaleUpCheck"
                                          Content="{DynamicResource ScaleUp}"
                                          Margin="0,0,0,6"/>
                                <CheckBox x:Name="ExtractAudioCheck"
                                          Content="{DynamicResource ExtractAudio}"/>
                            </StackPanel>

                        </StackPanel>

                        <!-- ==================== Fixed Bottom Progress Area ==================== -->
                        <Border Grid.Row="1"
                                Margin="0,10,0,0"
                                Padding="8"
                                Background="#FFFFFF"
                                BorderBrush="#D0D0D0"
                                BorderThickness="1"
                                CornerRadius="3">

                            <StackPanel>

                                <!-- ===== Progress Panel ===== -->
                                <StackPanel x:Name="ProgressPanel"
                                            Visibility="Collapsed">

                                    <ProgressBar x:Name="ProgressBar"
                                                 Height="12"
                                                 Minimum="0"
                                                 Maximum="100"/>

                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,6,0,0">
                                        <TextBlock x:Name="PassText"
                                                Width="60"/>
                                        <TextBlock x:Name="PercentText"
                                                Width="60"/>
                                        <TextBlock x:Name="EtaText"
                                                Width="80"/>
                                        <TextBlock x:Name="ElapsedText"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- ===== Result Panel ===== -->
                                <StackPanel x:Name="ResultPanel"
                                            Visibility="Collapsed"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            Margin="0,6,0,0">

                                    <TextBlock x:Name="OutputSizeText"
                                               VerticalAlignment="Center"
                                               Margin="0,0,12,0"/>

                                    <Button x:Name="OpenFolderButton"
                                            Content="Open Output Folder"
                                            Click="OpenFolder_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </TabItem>


            <!-- Tab 2: Log -->
            <TabItem Header="{DynamicResource LogTab}">
                <Border Background="#F8F9FA"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="10,8">

                    <!-- Bottom controls dock first -->
                    <DockPanel LastChildFill="True">

                        <StackPanel DockPanel.Dock="Bottom"
                                Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                Margin="0,10,0,0">
                            <CheckBox x:Name="AutoScrollCheck"
                                      Content="{DynamicResource AutoScroll}"
                                    IsChecked="True"
                                      Margin="0,0,10,0"
                                    VerticalAlignment="Center"/>
                            <Button Content="{DynamicResource SaveLog}"
                                    Padding="12,4"
                                    Click="SaveLog_Click"/>
                        </StackPanel>

                        <!-- LogBox fills remaining space (no Dock attribute) -->
                        <TextBox x:Name="LogBox"
                                AcceptsReturn="True"
                                IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto"
                                MinHeight="150"
                                Padding="6"
                                 TextWrapping="Wrap"
                                FontFamily="Consolas"
                                FontSize="11"/>
                    </DockPanel>

                </Border>
            </TabItem>
        </TabControl>

        <!-- ==================== Bottom: Language & Help ==================== -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">


            <!-- Start / Stop Buttons -->
            <UniformGrid Columns="2"
                         HorizontalAlignment="Center"
                         MaxWidth="240"
                    Margin="0,0,10,0">
                <Button x:Name="StartButton"
                        Content="{DynamicResource Start}"
                        Click="Start_Click"
                        Margin="0,0,8,0"
                        Padding="20,4"
                        FontSize="13"
                        FontWeight="SemiBold"
                        MinWidth="100"
                        Height="28"/>
                <Button x:Name="StopButton"
                        Content="{DynamicResource Stop}"
                        Click="Stop_Click"
                        Padding="20,4"
                        FontSize="13"
                        FontWeight="SemiBold"
                        MinWidth="100"
                        Height="28"/>
            </UniformGrid>

            <ComboBox x:Name="LanguageBox"
                      Width="90"
                      Margin="0,0,10,0"
                      VerticalContentAlignment="Center"
                      SelectionChanged="LanguageChanged">
                <ComboBoxItem Content="中文"/>
                <ComboBoxItem Content="English"/>
            </ComboBox>

            <Button Content="{DynamicResource About}"
                    Padding="12,4"
                    Click="About_Click"/>
        </StackPanel>
    </Grid>
</Window>